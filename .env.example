# MCP server identity reported to clients.
FLUX_SERVER_NAME=librechat-flux-mcp
FLUX_SERVER_VERSION=0.1.0

# HTTP server
# Bind address for the MCP HTTP server inside the process/container.
FLUX_HTTP_HOST=0.0.0.0
# Internal listening port for the MCP HTTP server.
FLUX_HTTP_PORT=3000
# Docker Compose port published on the host. Used by docker-compose.yml, not by Node itself.
FLUX_HTTP_PUBLISHED_PORT=3001
# MCP HTTP endpoint path.
FLUX_HTTP_MCP_PATH=/mcp
# Idle HTTP session timeout in milliseconds.
FLUX_HTTP_SESSION_IDLE_TIMEOUT_MS=900000
# How often idle sessions are swept in milliseconds.
FLUX_HTTP_SESSION_SWEEP_INTERVAL_MS=60000

# Provider setup
# Selects the upstream provider and determines endpoint/auth behavior.
# Available values:
# - direct-bfl: direct Black Forest Labs API using x-key authentication
# - azure-bfl: Azure Foundry BFL provider route using bearer authentication
FLUX_PROVIDER_KIND=direct-bfl
# Single provider base URL for the selected provider.
# direct-bfl examples:
# - https://api.bfl.ai
# - https://api.eu.bfl.ai
# - https://api.us.bfl.ai
# azure-bfl example:
# - https://<resource>.api.cognitive.microsoft.com
BASE_URL=https://api.bfl.ai
# Single API key for the selected provider.
# direct-bfl: BFL API key
# azure-bfl: Azure Foundry / Azure AI key
API_KEY=
# Active model for the whole MCP server.
# Supported values:
# - FLUX.2-pro
# - FLUX.2-flex
# - FLUX.1-Kontext-pro
# - FLUX-1.1-pro
MODEL=FLUX.2-pro
# Azure-only API version appended to the Azure provider route.
FLUX_PROVIDER_API_VERSION=preview
# direct-bfl only: stable or preview. Preview affects supported preview endpoints.
FLUX_PROVIDER_RELEASE_CHANNEL=stable

# Optional resumable HTTP replay
# Optional Redis connection string. When set, HTTP event replay/resume is enabled.
FLUX_REDIS_URL=
# SSE reconnect retry hint in milliseconds.
FLUX_HTTP_SSE_RETRY_INTERVAL_MS=1000
# Redis-backed event retention in seconds.
FLUX_HTTP_EVENT_TTL_SECONDS=3600
# Maximum retained events per Redis stream.
FLUX_HTTP_EVENT_MAX_STREAM_LENGTH=1000
# Redis key prefix for event streams.
FLUX_HTTP_EVENT_KEY_PREFIX=flux:mcp:sse

# Storage and runtime
# Directory where generated images are stored.
FLUX_OUTPUT_DIR=./data/flux/images
# JSON metadata index file path.
FLUX_METADATA_FILE=./data/flux/metadata.json
# Upstream request timeout in milliseconds.
FLUX_REQUEST_TIMEOUT_MS=240000
# Maximum concurrent upstream requests across submit/poll flows.
FLUX_MAX_PARALLEL_REQUESTS=2
# Maximum jobs created by a single variants request.
FLUX_VARIANTS_MAX_COUNT=4
# Feature flag for image import support.
FLUX_ENABLE_IMAGE_IMPORT=false

# Pino log level. Common values: trace, debug, info, warn, error, fatal.
LOG_LEVEL=info