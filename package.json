{
  "name": "librechat-flux-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/stdio.ts",
    "dev:http": "tsx watch src/http.ts",
    "probe:generate": "tsx scripts/probe-flux2pro-generate.ts",
    "probe:compose": "tsx scripts/probe-flux2pro-compose.ts",
    "start": "node dist/src/stdio.js",
    "start:http": "node dist/src/http.js",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^16.6.1",
    "pino": "^9.9.4",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}